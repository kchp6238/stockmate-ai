# =============================================
#  .env.example → .env 로 복사 후 값 채우기
#  절대로 GitHub에 올리지 마세요!
# =============================================

# [필수] Anthropic Claude API 키
# 발급: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-여기에_키_입력

# [선택] Finnhub API 키 (뉴스·기본정보 강화)
# 발급: https://finnhub.io  (무료 플랜 있음)
FINNHUB_API_KEY=여기에_키_입력

# [선택] Alpha Vantage API 키 (한국 주식 보완)
# 발급: https://www.alphavantage.co (무료 플랜 있음)
ALPHA_VANTAGE_KEY=여기에_키_입력

# 프론트엔드 주소 (CORS 허용 목록)
# 배포 후 Vercel 주소로 변경: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

# 환경 (development / production)
ENVIRONMENT=development
